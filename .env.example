# ===========================================
# IMPERIO MODAS - Configuracoes de Ambiente
# ===========================================
# Copie este arquivo para .env.local e preencha os valores

# ------------------------------------------
# MERCADO PAGO
# ------------------------------------------
# Obtenha em: https://www.mercadopago.com.br/developers/panel/credentials
# Use as credenciais de PRODUCAO para receber pagamentos reais
# Use as credenciais de TESTE para testar sem cobrar

# Access Token (obrigatorio para pagamentos)
MP_ACCESS_TOKEN=APP_USR-0000000000000000-000000-00000000000000000000000000000000-00000000

# ------------------------------------------
# URL DO SITE
# ------------------------------------------
# Em producao, coloque a URL real do site (ex: https://seusite.com.br)
# Em desenvolvimento local, deixe como localhost
NEXT_PUBLIC_BASE_URL=http://localhost:3000

# ------------------------------------------
# AUTENTICACAO ADMIN
# ------------------------------------------
# Chave secreta para gerar tokens JWT (mude para algo seguro!)
JWT_SECRET=sua-chave-secreta-aqui-mude-para-algo-seguro-123

# ------------------------------------------
# WHATSAPP (opcional)
# ------------------------------------------
# Numero do WhatsApp para receber notificacoes de pedidos
WHATSAPP_NUMBER=5549999999999
