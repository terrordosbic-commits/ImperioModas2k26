# ============================================
# SUPABASE - Banco de dados online (obrigatorio para Netlify/Vercel)
# ============================================
# Cole aqui a URL do seu projeto Supabase (Project Settings > API > URL)
SUPABASE_URL=https://seu-projeto.supabase.co

# Cole aqui a SERVICE ROLE KEY (Project Settings > API > service_role secret)
# IMPORTANTE: Nunca exponha esta chave no frontend!
SUPABASE_SERVICE_ROLE_KEY=sua-chave-service-role-secreta

# ============================================
# OPENAI - Chatbot inteligente (opcional)
# ============================================
# Se nao configurar, o chat funciona em modo fallback (resposta padrao)
OPENAI_API_KEY=sk-sua-chave-openai

# ============================================
# CONFIGURACAO LOCAL (modo desenvolvimento)
# ============================================
# Para rodar localmente sem Supabase, basta deixar as variaveis
# SUPABASE_URL e SUPABASE_SERVICE_ROLE_KEY em branco ou comentadas.
# O sistema vai usar automaticamente arquivos JSON na pasta data/.

